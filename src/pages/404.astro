---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found | Zach Beauvais Photographer"
  description="The page you were looking for could not be found."
  path="/404/"
>
  <section class="section page-hero">
    <div class="container stack">
      <p class="eyebrow">404</p>
      <h1 class="h1">That page is not here.</h1>
      <p class="lead measure">Try the homepage, the portrait sessions page, or the portfolio.</p>
      <div class="button-row">
        <a class="button button-primary" href="/">Go home</a>
        <a class="button button-secondary" href="/portfolio/collaborative/">View portraits</a>
      </div>
    </div>
  </section>
</BaseLayout>
