---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PackageCard from '../components/PackageCard.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import FAQList from '../components/FAQList.astro';

const faqItems = [
  {
    question: 'What kinds of portrait sessions do you photograph?',
    answer:
      'Portrait sessions can be shaped for social media, creative self-expression, personal branding, editorial-feeling portraits, or collaborative art-making.'
  },
  {
    question: 'How is editing handled?',
    answer:
      'Every session includes professional-level editing. The final images are intended to feel polished, intentional, and aligned with the mood we set together.'
  },
  {
    question: 'Where do you work?',
    answer:
      'Zach is based in Lafayette, Indiana. Sessions in Indianapolis, Urbana-Champaign, and Chicago are available for an additional $150 travel fee.'
  }
];
---

<BaseLayout
  title="Zach Beauvais Photographer | Artistic Portrait Photography in Lafayette, Indiana"
  description="Collaborative portrait photography shaped by landscape photography and mixed-media art. Based in Lafayette, Indiana."
  path="/"
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Lafayette, Indiana photographer</p>
        <h1 class="h1">Collaborative portrait photography shaped by landscape and contemporary art.</h1>
        <p class="lead measure">
          I make portraits with people, not just of them. My work blends artistic portraiture with the visual language
          of landscape photography and mixed-media art to create images that feel expressive, intentional, and personal.
        </p>
        <ul class="meta-list" aria-label="Key details">
          <li>Portraits for self-expression</li>
          <li>Brand and professional imagery</li>
          <li>Edited delivery included</li>
        </ul>
        <div class="button-row">
          <a class="button button-primary" href="/contact/">Book a session</a>
          <a class="button button-secondary" href="/portfolio/collaborative/">View portrait portfolio</a>
        </div>
      </div>

      <div class="hero-panel" role="img" aria-label="Abstract photographic collage placeholder for featured portrait work"></div>
    </div>
  </section>

  <section class="section surface-band">
    <div class="container stack">
      <SectionHeading
        eyebrow="Approach"
        title="Portrait sessions that leave room for collaboration, mood, and presence."
        intro="Whether the goal is a social profile, a brand refresh, or something more inward and exploratory, the process starts with conversation and ends with images that feel lived in rather than generic."
      />

      <div class="feature-grid">
        <div class="feature-item">
          <h3>Artistic collaboration</h3>
          <p>
            Sessions are guided, but not rigid. We can build around gesture, atmosphere, movement, styling, location,
            and the kind of story you want the images to hold.
          </p>
        </div>
        <div class="feature-item">
          <h3>Landscape-informed eye</h3>
          <p>
            My landscape background shapes how I work with light, weather, negative space, and environment. Even close
            portraits are built with a sense of place.
          </p>
        </div>
        <div class="feature-item">
          <h3>Mixed-media sensibility</h3>
          <p>
            I’m interested in texture, rhythm, contrast, and abstraction. That influence shows up in the way I frame,
            edit, and build a visual mood.
          </p>
        </div>
        <div class="feature-item">
          <h3>Professional editing included</h3>
          <p>
            Every package includes carefully edited final photographs so the work feels finished, cohesive, and ready to
            use or share.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="sessions">
    <div class="container stack">
      <SectionHeading
        eyebrow="Portrait sessions"
        title="Simple packages, thoughtfully edited."
        intro="Two portrait packages cover most needs, with extra travel available for Indianapolis, Urbana-Champaign, and Chicago."
      />

      <div class="package-grid">
        <PackageCard
          name="Single-location session"
          price="$350"
          description="A focused session for concise portraits, refreshed social imagery, or a collaborative short concept."
          items={[
            '1 hour',
            '1 location',
            '5 professionally edited photos',
            'Great for social, professional, or personal use'
          ]}
        />
        <PackageCard
          name="Extended portrait session"
          price="$750"
          description="More time, more variation, and more room to explore a fuller visual idea across location, styling, and mood."
          items={[
            '3 hours',
            '25 professionally edited photos',
            'Ideal for brands, expressive portraits, or a deeper collaborative concept',
            'Professional editing included'
          ]}
        />
      </div>

      <div class="note-card">
        <h3>Travel</h3>
        <p class="measure">
          Sessions in Indianapolis, Urbana-Champaign, and Chicago are available for an additional <strong>$150</strong>.
        </p>
        <ul class="location-list" aria-label="Travel locations">
          <li>Indianapolis</li>
          <li>Urbana-Champaign</li>
          <li>Chicago</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section surface-band">
    <div class="container stack">
      <SectionHeading
        eyebrow="Portfolio"
        title="Two bodies of work, one visual language."
        intro="The site is set up around your portrait practice and your landscape and abstract work, keeping the relationship between them visible without collapsing them together."
      />

      <div class="portfolio-highlight-grid">
        <PortfolioCard
          className="portrait-a"
          title="Collaborative / expressive portraits"
          body="Portrait work centred on mood, collaboration, and the expressive possibilities of light, gesture, and place."
          href="/portfolio/collaborative/"
          cta="See portrait portfolio"
        />
        <PortfolioCard
          className="landscape-a"
          title="Landscape / abstract"
          body="Landscape and abstract work that feeds the sensibility behind the portrait practice: atmosphere, structure, and visual tension."
          href="/portfolio/landscape/"
          cta="See landscape & abstract"
        />
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container stats-grid">
      <article class="stat-card">
        <p class="stat-value">2</p>
        <p class="stat-label">Portrait packages</p>
        <p>Clear session options without an overloaded pricing menu.</p>
      </article>
      <article class="stat-card">
        <p class="stat-value">3</p>
        <p class="stat-label">Travel cities</p>
        <p>Indianapolis, Urbana-Champaign, and Chicago are built into the offer.</p>
      </article>
      <article class="stat-card">
        <p class="stat-value">5–25</p>
        <p class="stat-label">Edited images</p>
        <p>Enough range for either a concise session or a more expansive story.</p>
      </article>
      <article class="stat-card">
        <p class="stat-value">1–3 hrs</p>
        <p class="stat-label">Session length</p>
        <p>Flexible enough for either focused portraits or deeper collaborative work.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <SectionHeading
        eyebrow="FAQ"
        title="A few practical details."
        intro="This keeps the site useful for people who are deciding whether to reach out now or come back later."
      />
      <FAQList items={faqItems} />
    </div>
  </section>

  <section class="section-tight">
    <div class="container cta-panel stack">
      <p class="eyebrow" style="color: rgba(253,252,251,0.72)">Get in touch</p>
      <h2>Interested in making something together?</h2>
      <p class="measure">
        Tell me what you want the images to do: update your presence, support your work, or explore something more
        personal. I’m also on Instagram at <a href="https://instagram.com/zach_of_the" target="_blank" rel="noopener noreferrer">@zach_of_the</a>.
      </p>
      <div class="button-row">
        <a class="button button-secondary" href="/contact/">Start a booking inquiry</a>
        <a class="button button-secondary" href="https://instagram.com/zach_of_the" target="_blank" rel="noopener noreferrer">Visit Instagram</a>
      </div>
    </div>
  </section>
</BaseLayout>
